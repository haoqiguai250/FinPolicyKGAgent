      },
      "relation": "leads_to",
      "object": {
        "name": "结果公示",
        "type": "Event"
      },
      "confidence": 1.0,
      "source_text": "（四）项目复审。区工业和信息化局对项目进行复审，确定专项资金拟资助计划，并经党组会审定后，形成部门审核意见。（五）结果公示。",
      "source_chunk_id": "chunk_015"
    },
