      "object": {
        "name": "项目复审",
        "type": "Event"
      },
      "confidence": 1.0,
      "source_text": "（三）专项审核。区工业和信息化局委托第三方专业机构对通过资格初审的项目申请材料真实性、完整性、有效性和合法性等方面进行专项审核和实地考察。（四）项目复审。",
      "source_chunk_id": "chunk_015"
    },
