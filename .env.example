# ============================================
# FinPolicyKG 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================

# DeepSeek LLM
# API Key 获取: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# 应用配置
APP_ENV=development
LOG_LEVEL=INFO
